generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model daily_logs {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id           String?   @db.Uuid
  date                 DateTime  @db.Date
  water_intake_glasses Int?      @default(0)
  steps_count          Int?      @default(0)
  mood                 String?   @db.VarChar(50)
  notes                String?
  profiles             profiles? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([profile_id, date])
  @@index([profile_id, date], map: "idx_daily_logs_date")
}

model meal_logs {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id          String?   @db.Uuid
  image_url           String
  ai_analysis         Json?
  nutritionist_review Json?
  status              String?   @default("pending") @db.VarChar(20)
  logged_at           DateTime? @default(now()) @db.Timestamptz(6)
  meal_category       String?   @default("other") @db.VarChar(50)
  compliance_status   String?   @default("pending") @db.VarChar(20)
  compliance_score    Int?      @default(100)
  violation_details   Json?
  water_ml            Int?      @default(0)
  supplements         String?
  physical_activity   String?
  serving_spoon_used  Boolean?  @default(false)
  image_after_url     String?
  cooking_method      String?   @db.VarChar(100)
  is_parent_verified  Boolean?  @default(false)
  hidden_ingredients  String?
  consumption_percent Int?      @default(100)
  total_calories      Int?      @default(0)
  total_protein_g     Float?    @default(0)
  total_carbs_g       Float?    @default(0)
  total_fat_g         Float?    @default(0)
  total_sugar_g       Float?    @default(0)
  total_sodium_mg     Int?      @default(0)
  profiles            profiles? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_meal_logs_profile")
}

model meal_plans {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id      String?   @db.Uuid
  date            DateTime  @db.Date
  meal_type       String    @db.VarChar(50)
  recipe_name     String
  calories        Int?
  protein_g       Int?
  carbs_g         Int?
  fats_g          Int?
  image_url       String?
  is_consumed     Boolean?  @default(false)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  recipe_id       String?   @db.VarChar(255)
  nutritionist_id String?   @db.Uuid
  users           users?    @relation(fields: [nutritionist_id], references: [id], onUpdate: NoAction)
  profiles        profiles? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id, date], map: "idx_meal_plans_date")
}

model nutrition_rules {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id      String?   @db.Uuid
  nutritionist_id String?   @db.Uuid
  category        String    @db.VarChar(50)
  rule_name       String    @db.VarChar(100)
  rule_definition Json
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
  rule_type       String?   @db.VarChar(20)
  rule_value      Decimal?  @db.Decimal
  rule_unit       String?   @db.VarChar(10)
  is_standard     Boolean?  @default(false)
  users           users?    @relation(fields: [nutritionist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles        profiles? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_nutrition_rules_profile")
}

model nutritionist_clients {
  id                                                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nutritionist_id                                   String?   @db.Uuid
  parent_id                                         String?   @db.Uuid
  status                                            String?   @default("active") @db.VarChar(20)
  created_at                                        DateTime? @default(now()) @db.Timestamptz(6)
  nutritionist                                      users?    @relation("nutritionist_clients_nutritionist_idTousers", fields: [nutritionist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent                                            users?    @relation("nutritionist_clients_parent_idTousers", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([nutritionist_id, parent_id])
  @@index([nutritionist_id], map: "idx_nutritionist_clients_nutri")
}

model nutritionist_notes {
  id              Int       @id @default(autoincrement())
  nutritionist_id String?   @db.Uuid
  client_id       String?   @db.Uuid
  content         String
  is_pinned       Boolean?  @default(false)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  client          profiles? @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nutritionist    users?    @relation(fields: [nutritionist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model profiles {
  id                  String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String?              @db.Uuid
  child_name          String               @db.VarChar(100)
  date_of_birth       DateTime?            @db.Date
  gender              String?              @db.VarChar(20)
  height_cm           Float?
  weight_kg           Float?
  activity_level      String?              @db.VarChar(50)
  allergies           String[]
  dietary_preferences String?
  created_at          DateTime?            @default(now()) @db.Timestamptz(6)
  calories_target     Int?
  protein_target      Int?
  carbs_target        Int?
  fat_target          Int?
  vaccinations        String?
  medications         String?
  weigh_in_conditions String?
  bristol_stool_scale Int?
  medical_history     String?
  family_history      String?
  food_intolerances   String?
  symptoms            String?
  lifestyle_factors   String?
  waist_circumference Float?
  weighing_time       String?   @db.VarChar(50)
  is_fasting          Boolean?  @default(false)
  is_post_voiding     Boolean?  @default(false)
  profile_image_url   String?
  daily_logs          daily_logs[]
  meal_logs           meal_logs[]
  meal_plans          meal_plans[]
  nutrition_rules     nutrition_rules[]
  notes               nutritionist_notes[]
  adime_notes         adime_notes[]
  growth_logs         growth_logs[]
  profile_vaccinations profile_vaccinations[]
  portion_plans       portion_plans[]
  daily_adherence_logs daily_adherence_logs[]
  users               users?               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model growth_logs {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id String?   @db.Uuid
  height_cm  Float
  weight_kg  Float
  logged_at  DateTime? @default(now()) @db.Timestamptz(6)
  
  profiles   profiles? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_growth_logs_profile")
}

model adime_notes {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id      String?   @db.Uuid
  nutritionist_id String?   @db.Uuid
  assessment      String?
  diagnosis       String?
  intervention    String?
  monitoring      String?
  evaluation      String?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
  
  profiles        profiles? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nutritionist    users?    @relation(fields: [nutritionist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_adime_notes_profile")
}

model users {
  id                                                               String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email                                                            String                 @unique @db.VarChar(255)
  password_hash                                                    String                 @db.VarChar(255)
  full_name                                                        String?                @db.VarChar(100)
  created_at                                                       DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at                                                       DateTime?              @default(now()) @db.Timestamptz(6)
  role                                                             String?                @default("parent") @db.VarChar(20)
  professional_id                                                  String?                @db.VarChar(50)
  phone                                                            String?                @db.VarChar(50)
  specialization                                                   String?                @db.VarChar(100)
  license_no                                                       String?                @db.VarChar(50)
  clinic                                                           String?                @db.VarChar(100)
  profile_image_url                                                String?
  meal_plans                                                       meal_plans[]
  nutrition_rules                                                  nutrition_rules[]
  clients             nutritionist_clients[] @relation("nutritionist_clients_nutritionist_idTousers")
  nutritionists       nutritionist_clients[] @relation("nutritionist_clients_parent_idTousers")
  notes               nutritionist_notes[]
  adime_notes         adime_notes[]
  status                                                           String?                @default("pending") @db.VarChar(20)
  is_suspended                                                     Boolean?               @default(false)
  force_password_reset                                             Boolean?               @default(false)
  license_image_url                                                String?
  date_of_birth                                                    DateTime?              @db.Date
  theme_preference                                                 String?                @default("light") @db.VarChar(20)
  privacy_mode                                                     Boolean?               @default(false)
  measurement_system                                               String?                @default("metric") @db.VarChar(20)
  nutrient_precision                                               String?                @default("whole") @db.VarChar(20)
  notif_compliance                                                 Boolean?               @default(true)
  notif_reminders                                                  Boolean?               @default(true)
  research_anonymize                                               Boolean?               @default(false)
  reset_password_token                                             String?                @db.VarChar(255)
  reset_password_expires                                           DateTime?              @db.Timestamptz(6)
  deleted_at                                                       DateTime?              @db.Timestamptz(6)
  deactivation_reason                                              String?                @db.VarChar(255)
  profiles                                                         profiles[]
  admin_audits                                                     audit_logs[]           @relation("admin_audits")
  target_audits                                                    audit_logs[]           @relation("target_audits")
  announcements                                                   announcements[]
  portion_plans                                                   portion_plans[]
  portion_templates                                               portion_templates[]
  meal_plan_templates                                             meal_plan_templates[]
}

model meal_plan_templates {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nutritionist_id String    @db.Uuid
  name            String    @db.VarChar(150)
  description     String?
  target_age      String?   @db.VarChar(50)
  days            Json      // { Monday: [{meal_type, recipe_name, calories, protein_g, carbs_g, fats_g}], ... }
  is_default      Boolean?  @default(false) // true = cloned from system defaults
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  nutritionist    users     @relation(fields: [nutritionist_id], references: [id], onDelete: Cascade)

  @@index([nutritionist_id], map: "idx_meal_plan_templates_nutri")
}

model portion_plans {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id      String?   @db.Uuid
  nutritionist_id String?   @db.Uuid
  meal_type       String    @db.VarChar(50) // Breakfast, AM Snack, Lunch, PM Snack, Dinner
  
  vegetables      String?   @db.VarChar(255)
  fruit           String?   @db.VarChar(255)
  milk            String?   @db.VarChar(255)
  rice            String?   @db.VarChar(255)
  meat            String?   @db.VarChar(255)
  fat             String?   @db.VarChar(255)
  sugar           String?   @db.VarChar(255)
  
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  profiles        profiles? @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  nutritionist    users?    @relation(fields: [nutritionist_id], references: [id])

  @@unique([profile_id, meal_type])
}

model portion_templates {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nutritionist_id String?   @db.Uuid
  template_name   String    @db.VarChar(100)
  matrix          Json      // Array of objects matching portion_plans schema without ids
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  users           users?    @relation(fields: [nutritionist_id], references: [id], onDelete: Cascade)
}

model daily_adherence_logs {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id      String    @db.Uuid
  date            DateTime  @db.Date
  meal_type       String    @db.VarChar(50)
  category        String    @db.VarChar(50)
  completed       Boolean   @default(false)
  
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  profiles        profiles  @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, date, meal_type, category])
}


model vaccination_types {
  id                  String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String               @unique @db.VarChar(100)
  description         String?
  profile_vaccinations profile_vaccinations[]
}

model profile_vaccinations {
  id                  String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  profile_id          String?           @db.Uuid
  vaccination_type_id String?           @db.Uuid
  date_administered   DateTime?         @db.Date
  notes               String?
  profiles            profiles?         @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vaccination_types   vaccination_types? @relation(fields: [vaccination_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_profile_vaccinations_profile")
}

model audit_logs {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  admin_id    String   @db.Uuid
  target_id   String?  @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String   @db.VarChar(50)
  entity_id   String?  @db.Uuid
  details     Json?
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  admin       users    @relation("admin_audits", fields: [admin_id], references: [id], onDelete: Cascade)
  target_user users?   @relation("target_audits", fields: [target_id], references: [id], onDelete: SetNull)

  @@index([admin_id])
  @@index([target_id])
  @@index([created_at])
}

model announcements {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String   @db.VarChar(255)
  content     String
  target_role String   @default("all") @db.VarChar(20)
  priority    String   @default("normal") @db.VarChar(20)
  admin_id    String   @db.Uuid
  is_active   Boolean  @default(true)
  expires_at  DateTime? @db.Timestamptz(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  admin       users    @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([target_role])
  @@index([is_active])
}
