# --- SERVER CONFIGURATION ---
PORT=5000
JWT_SECRET=your_jwt_secret_here

# --- DATABASE (Prisma/PostgreSQL) ---
# Format: postgres://username:password@localhost:5432/database_name
DATABASE_URL="postgres://postgres:password@localhost:5432/smartnutri"

# --- AI & EXTERNAL APIS ---
# Gemini API for Meal Generation
GEMINI_API_KEY=your_gemini_api_key_here

# Edamam API for Nutrition Analysis
EDAMAM_APP_ID=your_edamam_id
EDAMAM_APP_KEY=your_edamam_key
EDAMAM_USER_ID=your_edamam_user

# --- MEDIA STORAGE (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
